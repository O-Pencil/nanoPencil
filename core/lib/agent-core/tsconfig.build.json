{
	"compilerOptions": {
		"target": "ES2022",
		"module": "ESNext",
		"moduleResolution": "bundler",
		"lib": ["ES2022"],
		"outDir": "./dist",
		"rootDir": "./src",
		"strict": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"forceConsistentCasingInFileNames": true,
		"declaration": true,
		"declarationMap": false,
		"sourceMap": false,
		"resolveJsonModule": true,
		"baseUrl": ".",
		"paths": {
			"@catui/ai": ["../ai/dist/index.d.ts"],
			"@catui/ai/*": ["../ai/dist/*.d.ts"],
			"@catui/ai/oauth": ["../ai/dist/utils/oauth/index.d.ts"]
		},
		"incremental": true,
		"tsBuildInfoFile": "./.tsbuildinfo"
	},
	"include": ["src/**/*.ts"],
	"exclude": ["node_modules", "dist", "**/*.d.ts", "src/**/*.d.ts"]
}
