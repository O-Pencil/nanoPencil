{
  "name": "@pencil-agent/extension-sdk",
  "version": "0.1.0",
  "description": "Stable protocol contracts for NanoPencil extensions (tools, themes, hooks, commands, permissions, lifecycle)",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "scripts": {
    "build": "node ../../node_modules/typescript/bin/tsc -p tsconfig.json",
    "dev": "node ../../node_modules/typescript/bin/tsc -p tsconfig.json --watch",
    "clean": "node -e \"require('fs').rmSync('./dist',{recursive:true,force:true})\"",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "keywords": [
    "nanopencil",
    "extension",
    "sdk",
    "plugin",
    "agent"
  ],
  "author": "NanoPencil Team",
  "license": "GPL-3.0",
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "typescript": "^5.9.3"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/O-Pencil/nanoPencil.git"
  },
  "publishConfig": {
    "access": "public"
  }
}
