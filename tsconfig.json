{
  "compilerOptions": {
    "target": "ES2024",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "lib": ["ES2024"],
    "outDir": "./dist",
    "rootDir": ".",
    "strict": true,
    "noImplicitAny": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "types": ["node"],
    "paths": {
      "@catui/ai": ["./core/lib/ai/src/index.ts"],
      "@catui/ai/*": ["./core/lib/ai/src/*"],
      "@catui/ai/oauth": ["./core/lib/ai/src/utils/oauth/index.ts"],
      "@catui/agent-core": ["./core/lib/agent-core/src/index.ts"],
      "@catui/agent-core/*": ["./core/lib/agent-core/src/*"],
      "@catui/tui": ["./core/lib/tui/src/index.ts"],
      "@catui/tui/*": ["./core/lib/tui/src/*"],
      "@catui/mem-core": ["./packages/mem-core/src"],
      "@catui/soul-core": ["./packages/soul-core/src"],
      "@catui/protocol": ["./packages/protocol/src/index.ts"]
    }
  },
  "include": [
    "*.ts",
    "cli/**/*.ts",
    "core/**/*.ts",
    "modes/**/*.ts",
    "utils/**/*.ts",
    "extensions/**/*.ts",
  ],
  "exclude": ["node_modules", "dist", "core/lib"],
  "tscInternal": {
    "preservedWhitespace": true
  }
}
